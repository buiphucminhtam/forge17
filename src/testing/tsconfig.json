{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@testing/*": ["./src/testing/*"],
      "@core/*": ["./src/testing/core/*"],
      "@utils/*": ["./src/testing/utils/*"]
    }
  },
  "include": ["src/testing/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
