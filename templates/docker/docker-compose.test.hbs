# {{project.name}} — Test docker-compose
# Generated by Forgewright v8.1

services:
  {{project.slug}}-test:
    build:
      context: .
      dockerfile: Dockerfile
      target: builder
    container_name: {{project.slug}}-test
    environment:
      NODE_ENV: test
      PORT: {{default docker.port 3000}}
      {{#if docker.databaseUrl}}
      DATABASE_URL: {{docker.databaseUrl}}
      {{/if}}
    command: npm test -- --coverage --ci
    volumes:
      # Mount coverage results
      - ./coverage:/app/coverage

    # Isolated network (no external access)
    networks:
      - {{project.slug}}-test-net

    # Resource limits for CI environments
    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 512M

    # Health check
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:{{default docker.port 3000}}/health"]
      interval: 30s
      timeout: 10s
      retries: 3

{{#if docker.includeDb}}
  # Test database (isolated)
  postgres-test:
    image: postgres:16-alpine
    container_name: {{project.slug}}-postgres-test
    environment:
      POSTGRES_USER: {{project.slug}}
      POSTGRES_PASSWORD: testpassword
      POSTGRES_DB: {{project.slug}}_test
    networks:
      - {{project.slug}}-test-net
    # Resource limits
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 1G
    tmpfs:
      - /var/lib/postgresql/data

  redis-test:
    image: redis:7-alpine
    container_name: {{project.slug}}-redis-test
    networks:
      - {{project.slug}}-test-net
    command: redis-server --save "" --appendonly no
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 256M
{{/if}}

networks:
  {{project.slug}}-test-net:
    name: {{project.slug}}-test-network
    driver: bridge
