# {{project.name}} — Development docker-compose
# Generated by Forgewright v8.1

services:
  {{project.slug}}:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{project.slug}}-dev
    ports:
      - "{{default docker.port 3000}}:{{default docker.port 3000}}"
    volumes:
      # Mount source for hot reload (bind mount)
      - .:/app
      # Exclude node_modules to use container's dependencies
      - /app/node_modules
    environment:
      NODE_ENV: development
      PORT: {{default docker.port 3000}}
      {{#if docker.envVars}}
      {{#each docker.envVars}}
      {{@key}}: {{this}}
      {{/each}}
      {{/if}}
    command: npm run dev
    restart: unless-stopped

    # Development utilities
    stdin_open: true   # -i
    tty: true          # -t

    # Health check for dev convenience
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:{{default docker.port 3000}}/health"]
      interval: 30s
      timeout: 10s
      retries: 3

    # Networks
    networks:
      - {{project.slug}}-dev

{{#if docker.includeDb}}
  # Database (PostgreSQL example)
  postgres:
    image: postgres:16-alpine
    container_name: {{project.slug}}-postgres
    environment:
      POSTGRES_USER: {{project.slug}}
      POSTGRES_PASSWORD: devpassword
      POSTGRES_DB: {{project.slug}}_dev
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - {{project.slug}}-dev

  # Redis (for caching/sessions)
  redis:
    image: redis:7-alpine
    container_name: {{project.slug}}-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - {{project.slug}}-dev
{{/if}}

volumes:
  {{#if docker.includeDb}}
  postgres_data:
  redis_data:
  {{/if}}

networks:
  {{project.slug}}-dev:
    name: {{project.slug}}-dev-network
    driver: bridge
