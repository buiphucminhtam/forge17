# {{project.name}} — Game server docker-compose
# Generated by Forgewright v8.1

services:
  game-server:
    build:
      context: .
      dockerfile: Dockerfile.game
    container_name: {{project.slug}}-game-server
    ports:
      - "{{default docker.gamePort 34567}}:{{default docker.gamePort 34567}}/udp"
      {{#if docker.rconPort}}
      - "{{docker.rconPort}}:{{docker.rconPort}}/tcp"
      {{/if}}
    environment:
      SERVER_PORT: {{default docker.gamePort 34567}}
      {{#if docker.maxPlayers}}
      MAX_PLAYERS: {{docker.maxPlayers}}
      {{/if}}
      {{#if docker.gameMode}}
      GAME_MODE: {{docker.gameMode}}
      {{/if}}
      TICK_RATE: {{default docker.tickRate 64}}
    volumes:
      # Persistent game data
      - game-data:/data
      # Game logs
      - ./logs:/app/logs
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - game-network
    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 4G
        reservations:
          cpus: '1'
          memory: 2G

  {{#if docker.includeMatchmaker}}
  # Matchmaker service
  matchmaker:
    build:
      context: ./matchmaker
      dockerfile: Dockerfile
    container_name: {{project.slug}}-matchmaker
    ports:
      - "8080:8080"
    environment:
      GAME_SERVER_URL: http://game-server:{{default docker.gamePort 34567}}
      REDIS_URL: redis://redis:6379
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - game-network
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: {{project.slug}}-redis-game
    networks:
      - game-network
    volumes:
      - redis-game-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3
  {{/if}}

volumes:
  game-data:
  {{#if docker.includeMatchmaker}}
  redis-game-data:
  {{/if}}

networks:
  game-network:
    name: {{project.slug}}-game-network
    driver: bridge
