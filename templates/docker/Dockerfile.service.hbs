# syntax=docker/dockerfile:1
# {{name}} — Multi-stage Dockerfile
# Generated by Forgewright v8.1

# ─── Stage 1: Dependencies ───────────────────────────────────────────────────
FROM node:{{default docker.nodeVersion "20"}}-{{default docker.alpine "alpine"}} AS deps
WORKDIR /app

# Install only production dependencies first (better layer caching)
COPY package*.json ./
RUN npm ci --ignore-scripts

# ─── Stage 2: Build ──────────────────────────────────────────────────────────
FROM node:{{default docker.nodeVersion "20"}}-{{default docker.alpine "alpine"}} AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build TypeScript (if tsconfig exists)
{{#if docker.buildCommand}}
RUN {{docker.buildCommand}}
{{else}}
RUN npm run build 2>/dev/null || true
{{/if}}

# ─── Stage 3: Production ─────────────────────────────────────────────────────
FROM node:{{default docker.nodeVersion "20"}}-{{default docker.alpine "alpine"}} AS runner

# Security: Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S {{name}}-user -u 1001 -G nodejs

WORKDIR /app

# Copy only necessary files from builder
COPY --from=builder --chown={{name}}-user:nodejs /app/dist ./dist
COPY --from=builder --chown={{name}}-user:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown={{name}}-user:nodejs /app/package*.json ./

# Set environment
ENV NODE_ENV=production
ENV PORT={{default docker.port 3000}}

# Switch to non-root user
USER {{name}}-user

{{#if docker.healthCheck}}
# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:${PORT}/health || exit 1
{{/if}}

EXPOSE {{default docker.port 3000}}

# Use exec form for proper signal handling
CMD ["node", "dist/index.js"]
