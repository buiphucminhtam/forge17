# NetworkManager — Godot 4.x ENet Singleton
# Generated by Forgewright v8.1
# Autoload as "NetworkManager"
# Handles connection lifecycle and latency reporting

extends Node

## ─── Signals ───────────────────────────────────────────────────────────────────

signal connection_started()
signal connection_established(peer_id: int)
signal connection_failed(error: int)
signal server_disconnected()
signal peer_connected(peer_id: int)
signal peer_disconnected(peer_id: int)
signal latency_updated(peer_id: int, latency_ms: float)

## ─── Constants ─────────────────────────────────────────────────────────────────

const DEFAULT_PORT: int = {{default game.serverPort 34567}}
const MAX_PEERS: int = {{default game.maxConnections 8}}
const TIMEOUT_SEC: int = 10
const PING_INTERVAL_SEC: float = 1.0

## ─── Variables ─────────────────────────────────────────────────────────────────

var peer: ENetMultiplayerPeer
var is_server: bool = false
var is_client: bool = false
var is_connected: bool = false

var local_peer_id: int = 0
var peer_latencies: Dictionary = {}  # peer_id -> latency_ms
var _ping_timer: Timer
var _connection_timeout: Timer

## ─── Lifecycle ─────────────────────────────────────────────────────────────────

func _ready() -> void:
	multiplayer.peer_connected.connect(_on_peer_connected)
	multiplayer.peer_disconnected.connect(_on_peer_disconnected)
	multiplayer.connected_to_server.connect(_on_connected_to_server)
	multiplayer.connection_failed.connect(_on_connection_failed)
	multiplayer.server_disconnected.connect(_on_server_disconnected)

	_ping_timer = Timer.new()
	_ping_timer.timeout.connect(_send_ping)
	add_child(_ping_timer)

	_connection_timeout = Timer.new()
	_connection_timeout.one_shot = true
	_connection_timeout.timeout.connect(_on_connection_timeout)
	add_child(_connection_timeout)


## ─── Server Methods ─────────────────────────────────────────────────────────────

func create_server(port: int = DEFAULT_PORT, max_peers: int = MAX_PEERS) -> Error:
	"""Create and host a game server."""
	peer = ENetMultiplayerPeer.new()
	var err = peer.create_server(port, max_peers)
	if err != OK:
		push_error("Failed to create server: %s" % str(err))
		return err

	peer.get_host().compress(ENetConnection.COMPRESS_RANGE_CODER)
	multiplayer.multiplayer_peer = peer

	is_server = true
	is_client = false
	is_connected = true
	local_peer_id = 1  # Server is always peer 1

	_start_ping_timer()
	connection_started.emit()
	connection_established.emit(local_peer_id)

	print("Server created on port %d" % port)
	return OK


func close_server() -> void:
	"""Close the server and disconnect all peers."""
	_stop_ping_timer()
	if peer and peer.get_connection_state() == ENetMultiplayerPeer.CONNECTION_CONNECTED:
		peer.close()
	_multiplayer_reset()


## ─── Client Methods ─────────────────────────────────────────────────────────────

func join_server(address: String, port: int = DEFAULT_PORT) -> Error:
	"""Connect to a game server."""
	peer = ENetMultiplayerPeer.new()
	var err = peer.create_client(address, port)
	if err != OK:
		push_error("Failed to create client: %s" % str(err))
		return err

	peer.get_host().compress(ENetConnection.COMPRESS_RANGE_CODER)
	multiplayer.multiplayer_peer = peer

	is_server = false
	is_client = true
	is_connected = true

	_connection_timeout.start(TIMEOUT_SEC)
	connection_started.emit()

	print("Connecting to %s:%d..." % [address, port])
	return OK


func disconnect_client() -> void:
	"""Disconnect from the server."""
	_stop_ping_timer()
	_connection_timeout.stop()
	if peer:
		peer.close()
	_multiplayer_reset()


## ─── Latency Management ────────────────────────────────────────────────────────

func _send_ping() -> void:
	if not is_connected:
		return

	if is_server:
		# Server pings all peers
		for peer_id in multiplayer.get_peers():
			var sent_time = Time.get_ticks_msec()
			_ping_request.rpc_id(peer_id, sent_time)
	else:
		# Client pings server
		var sent_time = Time.get_ticks_msec()
		_ping_request.rpc_id(1, sent_time)  # Server is always ID 1


@rpc
func _ping_request(sent_time: int) -> void:
	# Echo back immediately
	_ping_response.rpc_id(multiplayer.get_remote_sender_id(), sent_time)


@rpc
func _ping_response(sent_time: int) -> void:
	var latency = (Time.get_ticks_msec() - sent_time) / 2.0
	var sender_id = multiplayer.get_remote_sender_id()
	peer_latencies[sender_id] = latency
	latency_updated.emit(sender_id, latency)


func get_latency(peer_id: int) -> float:
	"""Get latency to a peer in milliseconds."""
	return peer_latencies.get(peer_id, 0.0)


func get_average_latency() -> float:
	"""Get average latency across all peers."""
	if peer_latencies.is_empty():
		return 0.0
	var sum = 0.0
	for latency in peer_latencies.values():
		sum += latency
	return sum / peer_latencies.size()


## ─── Connection State ─────────────────────────────────────────────────────────

func get_connection_state() -> ENetMultiplayerPeer.State:
	if peer:
		return peer.get_connection_state()
	return ENetMultiplayerPeer.STATE_DISCONNECTED


func is_connection_stable() -> bool:
	"""Check if connection is stable (no high latency)."""
	var avg_latency = get_average_latency()
	return avg_latency < 200.0  # 200ms threshold


## ─── Private Methods ────────────────────────────────────────────────────────────

func _start_ping_timer() -> void:
	_ping_timer.start(PING_INTERVAL_SEC)


func _stop_ping_timer() -> void:
	_ping_timer.stop()


func _multiplayer_reset() -> void:
	is_server = false
	is_client = false
	is_connected = false
	local_peer_id = 0
	peer_latencies.clear()


func _on_connection_timeout() -> void:
	connection_failed.emit(ERR_TIMEOUT)
	disconnect_client()


## ─── Network Callbacks ────────────────────────────────────────────────────────

func _on_peer_connected(peer_id: int) -> void:
	print("Peer connected: %d" % peer_id)
	peer_latencies[peer_id] = 0.0
	peer_connected.emit(peer_id)


func _on_peer_disconnected(peer_id: int) -> void:
	print("Peer disconnected: %d" % peer_id)
	peer_latencies.erase(peer_id)
	peer_disconnected.emit(peer_id)


func _on_connected_to_server() -> void:
	_connection_timeout.stop()
	local_peer_id = multiplayer.get_unique_id()
	is_connected = true
	_start_ping_timer()
	connection_established.emit(local_peer_id)


func _on_connection_failed(error: int) -> void:
	_connection_timeout.stop()
	is_connected = false
	connection_failed.emit(error)


func _on_server_disconnected() -> void:
	_stop_ping_timer()
	is_connected = false
	server_disconnected.emit()
