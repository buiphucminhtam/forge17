# Lobby System — Godot 4.x Multiplayer
# Generated by Forgewright v8.1
# Extends Node2D/Node, handles player management and game start

class_name Lobby
extends Node2D

## ─── Signals ───────────────────────────────────────────────────────────────────

signal player_joined(player_info: Dictionary)
signal player_left(player_id: int)
signal player_ready_changed(player_id: int, is_ready: bool)
signal game_started()
signal host_migrated(new_host_id: int)

## ─── Constants ─────────────────────────────────────────────────────────────────

const MAX_PLAYERS: int = {{default game.maxPlayers 4}}
const LOBBY_TIMEOUT_SEC: int = 60

## ─── Variables ─────────────────────────────────────────────────────────────────

var is_in_lobby: bool = false
var is_host: bool = false
var local_player_id: int = -1
var local_player_info: Dictionary = {}

var players: Dictionary = {}  # player_id -> player_info
var ready_players: Dictionary = {}  # player_id -> is_ready
var player_count: int:
	get: return players.size()

var lobby_code: String = ""
var game_scene: PackedScene = preload("res://scenes/game.tscn")
var can_start_game: bool:
	get:
		if players.size() < 2:
			return false
		return players.values().all(func(p: Dictionary) -> bool:
			return ready_players.get(p.get("id", -1), false)
		)

var _lobby_timer: Timer
var _poll_timer: Timer

## ─── Lifecycle ─────────────────────────────────────────────────────────────────

func _ready() -> void:
	# Set up multiplayer
	multiplayer.peer_connected.connect(_on_peer_connected)
	multiplayer.peer_disconnected.connect(_on_peer_disconnected)
	multiplayer.connected_to_server.connect(_on_connected_to_server)
	multiplayer.connection_failed.connect(_on_connection_failed)
	multiplayer.server_disconnected.connect(_on_server_disconnected)

	# Create timers
	_lobby_timer = Timer.new()
	_lobby_timer.timeout.connect(_on_lobby_timeout)
	add_child(_lobby_timer)

	_poll_timer = Timer.new()
	_poll_timer.timeout.connect(_poll_lobby_state)
	_poll_timer.start(1.0)
	add_child(_poll_timer)

## ─── Public Methods ─────────────────────────────────────────────────────────────

func create_lobby(host_info: Dictionary) -> bool:
	"""Create a new lobby as host."""
	var peer = ENetMultiplayerPeer.new()
	var error = peer.create_server({{default game.serverPort 34567}}, MAX_PLAYERS)
	if error != OK:
		push_error("Failed to create server: %d" % error)
		return false

	multiplayer.multiplayer_peer = peer
	local_player_id = 1  # Host is always ID 1
	is_host = true
	is_in_lobby = true

	players[local_player_id] = host_info.duplicate(true)
	players[local_player_id]["id"] = local_player_id
	players[local_player_id]["is_host"] = true
	local_player_info = players[local_player_id]
	ready_players[local_player_id] = false

	_update_lobby_code()
	_rpc_update_players.rpc(players, ready_players, lobby_code)

	player_joined.emit(players[local_player_id])
	return true


func join_lobby(code: String, player_info: Dictionary) -> bool:
	"""Join an existing lobby."""
	lobby_code = code

	var peer = ENetMultiplayerPeer.new()
	# Parse code to get host address (simplified)
	var error = peer.create_client("localhost", {{default game.serverPort 34567}})
	if error != OK:
		push_error("Failed to connect: %d" % error)
		return false

	multiplayer.multiplayer_peer = peer

	local_player_info = player_info.duplicate(true)
	# Wait for server to assign player ID
	_set_in_lobby(true)
	return true


func leave_lobby() -> void:
	"""Leave the current lobby."""
	if is_in_lobby:
		_rpc_notify_leave.rpc(local_player_id)
		_close_lobby()


func set_ready(is_ready: bool) -> void:
	"""Set local player ready state."""
	if not is_in_lobby:
		return
	ready_players[local_player_id] = is_ready
	_rpc_update_ready.rpc(local_player_id, is_ready)


func start_game() -> void:
	"""Host starts the game."""
	if not is_host or not can_start_game:
		return

	_rpc_start_game.rpc()


func kick_player(player_id: int) -> void:
	"""Kick a player (host only)."""
	if not is_host or player_id == local_player_id:
		return

	if players.has(player_id):
		_kick_player.rpc_id(player_id)
		_remove_player(player_id)


## ─── Network RPCs ─────────────────────────────────────────────────────────────

@rpc(any_peer)
func _rpc_update_players(new_players: Dictionary, new_ready: Dictionary, new_code: String) -> void:
	players = new_players.duplicate(true)
	ready_players = new_ready.duplicate(true)
	lobby_code = new_code
	_update_ui()


@rpc(any_peer)
func _rpc_update_ready(player_id: int, is_ready: bool) -> void:
	ready_players[player_id] = is_ready
	player_ready_changed.emit(player_id, is_ready)
	_update_ui()


@rpc(any_peer)
func _rpc_notify_leave(player_id: int) -> void:
	_remove_player(player_id)


@rpc(any_peer)
func _rpc_start_game() -> void:
	game_started.emit()
	# Transition to game scene
	get_tree().change_scene_to_packed(game_scene)


@rpc
func _rpc_assign_player_id(id: int, info: Dictionary) -> void:
	local_player_id = id
	local_player_info = info.duplicate(true)
	local_player_info["id"] = id
	players[id] = local_player_info
	ready_players[id] = false


@rpc(any_peer)
func _rpc_sync_player_info(player_info: Dictionary) -> void:
	var sender_id = multiplayer.get_remote_sender_id()
	if players.has(sender_id):
		players[sender_id] = player_info.duplicate(true)
		players[sender_id]["id"] = sender_id


@rpc
func _kick_player() -> void:
	_close_lobby()
	# Show "kicked" message


@rpc(any_peer)
func _rpc_host_migration(new_host_id: int) -> void:
	is_host = (new_host_id == local_player_id)
	for p in players.values():
		p["is_host"] = (p["id"] == new_host_id)
	host_migrated.emit(new_host_id)


## ─── Private Methods ────────────────────────────────────────────────────────────

func _on_peer_connected(peer_id: int) -> void:
	print("Player connected: %d" % peer_id)
	# Host assigns ID and broadcasts player list
	if is_host:
		# Request player info from new peer
		_rpc_assign_player_id.rpc_id(peer_id, local_player_info)
		# Broadcast updated player list
		var updated_players = players.duplicate(true)
		var updated_ready = ready_players.duplicate(true)
		_rpc_update_players.rpc_id(peer_id, updated_players, updated_ready, lobby_code)


func _on_peer_disconnected(peer_id: int) -> void:
	print("Player disconnected: %d" % peer_id)
	if is_host:
		_remove_player(peer_id)
	else:
		# Notify host
		_rpc_notify_leave.rpc(local_player_id)


func _remove_player(player_id: int) -> void:
	if players.has(player_id):
		var info = players[player_id]
		players.erase(player_id)
		ready_players.erase(player_id)
		player_left.emit(player_id)

		# Check if host left - trigger migration
		if info.get("is_host", false) and players.size() > 0:
			var new_host_id = players.keys()[0]
			players[new_host_id]["is_host"] = true
			_rpc_host_migration.rpc(new_host_id)


func _close_lobby() -> void:
	is_in_lobby = false
	is_host = false
	players.clear()
	ready_players.clear()
	local_player_id = -1
	local_player_info.clear()
	if multiplayer.multiplayer_peer:
		multiplayer.multiplayer_peer.close()
		multiplayer.multiplayer_peer = null


func _update_lobby_code() -> void:
	# Generate random 6-character code
	var chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"
	lobby_code = ""
	for i in range(6):
		lobby_code += chars[randi() % chars.length()]


func _poll_lobby_state() -> void:
	"""Periodically sync state."""
	if is_host and is_in_lobby:
		_rpc_update_players.rpc(players, ready_players, lobby_code)
	_update_ui()


func _on_lobby_timeout() -> void:
	# Lobby idle timeout - notify players
	pass


func _update_ui() -> void:
	# Override in subclass or connect to UI
	pass


