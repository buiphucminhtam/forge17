# SyncVar — Godot 4.x Property Synchronization Helper
# Generated by Forgewright v8.1
# Provides automatic property sync with authority management

extends Node
class_name SyncVar

## ─── SyncVar Core ──────────────────────────────────────────────────────────────
# Attach this to any Node to enable automatic property synchronization
# Properties marked with @export_sync will sync across network

## ─── Usage ────────────────────────────────────────────────────────────────────
# 1. Attach SyncVar to a networked node
# 2. Mark properties with @export_sync annotation
# 3. Set authority with set_network_authority()
# 4. Changes to synced properties propagate automatically

## ─── Signals ───────────────────────────────────────────────────────────────────

signal property_synced(property_name: String, value: Variant)
signal sync_completed()

## ─── Sync Settings ─────────────────────────────────────────────────────────────

enum SyncMode {
	MANUAL,      # Manual sync via sync()
	ON_CHANGE,   # Sync immediately on change
	TICK_BASED,  # Sync on server tick
}

@export var sync_mode: SyncMode = SyncMode.ON_CHANGE
@export var tick_rate: int = {{default game.tickRate 64}}  # ticks per second
@export var interpolation: bool = true
@export var interpolation_time: float = 0.1

## ─── Internal State ────────────────────────────────────────────────────────────

var _synced_properties: Dictionary = {}  # property_name -> {value, last_update}
var _authority_peer_id: int = 1
var _is_authority: bool = false
var _local_cache: Dictionary = {}  # For interpolation
var _target_values: Dictionary = {}  # Interpolation targets

var _tick_timer: Timer
var _interpolation_timer: Timer

## ─── Lifecycle ─────────────────────────────────────────────────────────────────

func _ready() -> void:
	if sync_mode == SyncMode.TICK_BASED:
		_tick_timer = Timer.new()
		_tick_timer.timeout.connect(_on_tick)
		_tick_timer.start(1.0 / tick_rate)
		add_child(_tick_timer)

	if interpolation:
		_interpolation_timer = Timer.new()
		_interpolation_timer.timeout.connect(_interpolate)
		_interpolation_timer.start(1.0 / 30.0)  # 30 FPS interpolation
		add_child(_interpolation_timer)

	# Get initial authority
	if is_network_valid():
		set_network_authority(get_network_authority())


func _get(property: StringName) -> Variant:
	if _synced_properties.has(property):
		return _synced_properties[property]["value"]
	return get(property.lstrip("_"))


func _set(property: StringName, value: Variant) -> bool:
	if _synced_properties.has(property):
		var old_value = _synced_properties[property]["value"]
		if old_value != value:
			_synced_properties[property]["value"] = value
			_on_synced_property_changed(property, value, old_value)
		return true
	return false


## ─── Authority Management ──────────────────────────────────────────────────────

func set_network_authority(peer_id: int) -> void:
	_authority_peer_id = peer_id
	_is_authority = (peer_id == multiplayer.get_unique_id())

	if _is_authority:
		_enable_authority()
	else:
		_disable_authority()


func _enable_authority() -> void:
	# Authority can write to synced properties
	set_process_input(true)


func _disable_authority() -> void:
	# Non-authoritative peers read from network
	set_process_input(false)


## ─── Property Registration ────────────────────────────────────────────────────

func register_sync_property(property_name: String, initial_value: Variant = null) -> void:
	if initial_value == null:
		initial_value = get(property_name)

	_synced_properties[property_name] = {
		"value": initial_value,
		"last_update": Time.get_ticks_msec(),
	}
	_local_cache[property_name] = initial_value
	_target_values[property_name] = initial_value


## ─── Sync RPCs ────────────────────────────────────────────────────────────────

@rpc(any_peer)
func _sync_property(property_name: String, value: Variant, timestamp: int) -> void:
	var sender_id = multiplayer.get_remote_sender_id()
	if sender_id != _authority_peer_id and _authority_peer_id != 0:
		return  # Only authority can sync

	if _synced_properties.has(property_name):
		_synced_properties[property]["value"] = value
		_synced_properties[property]["last_update"] = timestamp

		if interpolation:
			_target_values[property_name] = value
		else:
			_local_cache[property_name] = value

	property_synced.emit(property_name, value)


@rpc(any_peer)
func _sync_batch(properties: Dictionary, timestamp: int) -> void:
	for property_name in properties:
		if _synced_properties.has(property_name):
			_synced_properties[property_name]["value"] = properties[property_name]
			_synced_properties[property_name]["last_update"] = timestamp
			if interpolation:
				_target_values[property_name] = properties[property_name]

	sync_completed.emit()


@rpc(unreliable, any_peer)
func _sync_interpolated(properties: Dictionary, target_timestamp: int) -> void:
	for property_name in properties:
		if _synced_properties.has(property_name):
			var current_target = _target_values.get(property_name, properties[property_name])
			_target_values[property_name] = properties[property_name]
			_local_cache[property_name] = current_target


## ─── Manual Sync ──────────────────────────────────────────────────────────────

func sync_property(property_name: String) -> void:
	if not _is_authority:
		return
	if not _synced_properties.has(property_name):
		return

	var value = _synced_properties[property_name]["value"]
	var timestamp = Time.get_ticks_msec()
	_sync_property.rpc(property_name, value, timestamp)


func sync_all() -> void:
	if not _is_authority:
		return

	var properties = {}
	var timestamp = Time.get_ticks_msec()
	for property_name in _synced_properties:
		properties[property_name] = _synced_properties[property_name]["value"]

	_sync_batch.rpc(properties, timestamp)


## ─── Interpolation ────────────────────────────────────────────────────────────

func _interpolate() -> void:
	if not interpolation or _is_authority:
		return

	var delta = _interpolation_timer.wait_time
	for property_name in _local_cache:
		var current = _local_cache[property_name]
		var target = _target_values.get(property_name, current)

		if typeof(current) == TYPE_FLOAT and typeof(target) == TYPE_FLOAT:
			_local_cache[property_name] = lerp(current, target, delta / interpolation_time)


## ─── Tick-Based Sync ──────────────────────────────────────────────────────────

func _on_tick() -> void:
	if _is_authority:
		sync_all()


## ─── Change Detection ─────────────────────────────────────────────────────────

func _on_synced_property_changed(property_name: String, new_value: Variant, old_value: Variant) -> void:
	match sync_mode:
		SyncMode.ON_CHANGE:
			sync_property(property_name)
		SyncMode.TICK_BASED:
			pass  # Sync on next tick
		SyncMode.MANUAL:
			pass  # Manual sync only


## ─── Helper Methods ────────────────────────────────────────────────────────────

func is_authority() -> bool:
	return _is_authority


func get_authority_id() -> int:
	return _authority_peer_id


func get_network_value(property_name: String) -> Variant:
	if _synced_properties.has(property_name):
		return _synced_properties[property_name]["value"]
	return null


func get_local_value(property_name: String) -> Variant:
	return _local_cache.get(property_name, null)


func reset_property(property_name: String, value: Variant) -> void:
	register_sync_property(property_name, value)
	if _is_authority:
		sync_property(property_name)
