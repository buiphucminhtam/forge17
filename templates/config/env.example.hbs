# Environment Variables Template
# Generated by Forgewright v8.1
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT={{default env.port 3000}}
APP_NAME={{project.name}}
APP_VERSION={{project.version}}

# ─── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:{{default env.port 3000}}
API_KEY=
API_SECRET=

# ─── Database ──────────────────────────────────────────────────────────────────
{{#if env.databaseType}}
DATABASE_URL={{#if (eq env.databaseType "postgresql")}}postgresql://user:password@localhost:5432/{{project.slug}}{{else if (eq env.databaseType "mysql")}}mysql://user:password@localhost:3306/{{project.slug}}{{else if (eq env.databaseType "mongodb")}}mongodb://user:password@localhost:27017/{{project.slug}}{{else}}postgresql://user:password@localhost:5432/{{project.slug}}{{/if}}
{{else}}
DATABASE_URL=postgresql://user:password@localhost:5432/{{project.slug}}
{{/if}}
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=5000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX={{project.slug}}:
{{#if env.redisPassword}}
REDIS_PASSWORD={{env.redisPassword}}
{{/if}}

# ─── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAuth ─────────────────────────────────────────────────────────────────────
{{#if env.oauthProviders}}
{{#each env.oauthProviders}}
{{this | uppercase}}_CLIENT_ID=
{{this | uppercase}}_CLIENT_SECRET=
{{this | uppercase}}_CALLBACK_URL=http://localhost:{{default env.port 3000}}/auth/{{this}}/callback
{{/each}}
{{/if}}

# ─── External Services ──────────────────────────────────────────────────────────
{{#if env.sentryDsn}}
SENTRY_DSN={{env.sentryDsn}}
SENTRY_ENVIRONMENT=development
{{/if}}

{{#if env.openaiKey}}
OPENAI_API_KEY={{env.openaiKey}}
{{/if}}

# ─── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_NEW_UI=false
FEATURE_BETA=false

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ─── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ─── Development ───────────────────────────────────────────────────────────────
{{#if env.enableDebug}}
DEBUG={{project.slug}}:*,
{{/if}}
{{#if env.enableInspector}}
INSPECT_PORT=9229
{{/if}}
