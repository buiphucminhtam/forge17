# EditorConfig — Standard coding style
# Generated by Forgewright v8.1
# https://editorconfig.org/

root = true

# ─── All Files ─────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# ─── Markdown & Text ───────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ─── JSON & YAML ───────────────────────────────────────────────────────────────
[*.{json,jsonc}]
indent_size = 2
max_line_length = 120

[*.{yaml,yml}]
indent_size = 2

# ─── TypeScript & JavaScript ───────────────────────────────────────────────────
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.d.ts]
indent_size = 2

# ─── HTML & CSS ────────────────────────────────────────────────────────────────
[*.{html,htm}]
indent_size = 2
max_line_length = 120

[*.{css,scss,sass,less}]
indent_size = 2

# ─── Shell Scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_size = 2

# ─── Dockerfile ─────────────────────────────────────────────────────────────────
[Dockerfile*]
indent_size = 2

# ─── Makefile ──────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ─── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 88

# ─── Go ────────────────────────────────────────────────────────────────────────
[*.go]
indent_size = 4
max_line_length = 120

# ─── Java ─────────────────────────────────────────────────────────────────────
[*.java]
indent_size = 4
max_line_length = 120

# ─── C Family ─────────────────────────────────────────────────────────────────
[*.{c,cpp,h,hpp}]
indent_size = 4
max_line_length = 120

# ─── Vim ───────────────────────────────────────────────────────────────────────
[*.vim]
indent_size = 2
expandtab = true
