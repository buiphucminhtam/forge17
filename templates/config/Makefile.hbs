# Makefile — Common build targets
# Generated by Forgewright v8.1
# Requires GNU Make 4.0+

.SHELL := /bin/bash
.DELETE_ON_ERROR:
.SUFFIXES:

# ─── Variables ──────────────────────────────────────────────────────────────────
PROJECT := {{project.name}}
VERSION := {{project.version}}
NODE := $(shell which node)
NPM := $(shell which npm)
DOCKER := $(shell which docker)
ENV ?= development

# ─── Colors ────────────────────────────────────────────────────────────────────
BOLD := \033[1m
GREEN := \033[0;32m
YELLOW := \033[0;33m
RED := \033[0;31m
NC := \033[0m # No Color

define info
	@printf "$(BOLD)$(GREEN)[INFO]$(NC) %s\n" "$(1)"
endef

define warn
	@printf "$(BOLD)$(YELLOW)[WARN]$(NC) %s\n" "$(1)"
endef

define error
	@printf "$(BOLD)$(RED)[ERROR]$(NC) %s\n" "$(1)"
endef

# ─── Help ──────────────────────────────────────────────────────────────────────
.PHONY: help
help: ## Show this help
	@awk 'BEGIN {FS = ":.*?## "} /^[a-zA-Z_-]+:.*?## / {printf "  $(BOLD)%-18s$(NC) %s\n", $$1, $$2}' $(MAKEFILE_LIST)

# ─── Installation ───────────────────────────────────────────────────────────────
.PHONY: install
install: ## Install dependencies
	$(call info,Installing dependencies...)
	npm ci

# ─── Development ────────────────────────────────────────────────────────────────
.PHONY: dev
dev: ## Start development server
	$(call info,Starting dev server...)
	npm run dev

.PHONY: build
build: ## Build for production
	$(call info,Building for $(ENV)...)
	npm run build

.PHONY: start
start: ## Start production server
	$(call info,Starting production server...)
	NODE_ENV=production npm start

# ─── Testing ────────────────────────────────────────────────────────────────────
.PHONY: test
test: ## Run tests
	$(call info,Running tests...)
	npm test

.PHONY: test:watch
test:watch: ## Run tests in watch mode
	$(call info,Running tests in watch mode...)
	npm test -- --watch

.PHONY: test:coverage
test:coverage: ## Run tests with coverage
	$(call info,Running tests with coverage...)
	npm test -- --coverage

.PHONY: test:e2e
test:e2e: ## Run E2E tests
	$(call info,Running E2E tests...)
	npm run test:e2e

# ─── Linting & Formatting ────────────────────────────────────────────────────────
.PHONY: lint
lint: ## Run linter
	$(call info,Running linter...)
	npm run lint

.PHONY: lint:fix
lint:fix: ## Fix linting issues
	$(call info,Fixing linting issues...)
	npm run lint:fix

.PHONY: format
format: ## Format code
	$(call info,Formatting code...)
	npm run format

.PHONY: check
check: lint typecheck test ## Run all checks (lint, typecheck, test)

# ─── Type Checking ─────────────────────────────────────────────────────────────
.PHONY: typecheck
typecheck: ## Type check
	$(call info,Type checking...)
	npx tsc --noEmit

# ─── Docker ─────────────────────────────────────────────────────────────────────
.PHONY: docker:build
docker:build: ## Build Docker image
	$(call info,Building Docker image...)
	docker build -t $(PROJECT):$(VERSION) .

.PHONY: docker:up
docker:up: ## Start containers
	$(call info,Starting containers...)
	docker-compose up -d

.PHONY: docker:down
docker:down: ## Stop containers
	$(call info,Stopping containers...)
	docker-compose down

.PHONY: docker:logs
docker:logs: ## View logs
	docker-compose logs -f

# ─── Database ───────────────────────────────────────────────────────────────────
.PHONY: db:migrate
db:migrate: ## Run migrations
	$(call info,Running migrations...)
	npm run db:migrate

.PHONY: db:rollback
db:rollback: ## Rollback last migration
	$(call info,Rolling back migration...)
	npm run db:rollback

.PHONY: db:seed
db:seed: ## Seed database
	$(call info,Seeding database...)
	npm run db:seed

.PHONY: db:reset
db:reset: ## Reset database
	$(call info,Resetting database...)
	npm run db:reset

# ─── Utilities ──────────────────────────────────────────────────────────────────
.PHONY: clean
clean: ## Clean build artifacts
	$(call info,Cleaning...)
	rm -rf dist build coverage .next .nuxt
	npm cache clean --force

.PHONY: clean:all
clean:all: clean docker:down ## Clean everything including containers

.PHONY: depcheck
depcheck: ## Check for outdated dependencies
	$(call info,Checking dependencies...)
	npx depcheck || true

.PHONY: outdated
outdated: ## List outdated packages
	$(call info,Listing outdated packages...)
	npm outdated

.PHONY: audit
audit: ## Security audit
	$(call info,Running security audit...)
	npm audit

# ─── Release ────────────────────────────────────────────────────────────────────
.PHONY: release
release: ## Create release
	$(call info,Creating release v$(VERSION)...)
	npm version patch && git push --tags

.PHONY: changelog
changelog: ## Generate changelog
	$(call info,Generating changelog...)
	npx conventional-changelog -p angular -i CHANGELOG.md -s
