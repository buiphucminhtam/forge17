// ─── Core Assertions ───────────────────────────────────────────────────────────

export const assertions = {
  // ─── Element Assertions ──────────────────────────────────────────────────────

  /**
   * Assert element is visible with retry logic
   */
  async toBeVisible(
    driver: WebdriverIO.Browser,
    selector: string,
    options?: { timeout?: number; retry?: number }
  ): Promise<boolean> {
    const { timeout = 10000, retry = 3 } = options ?? {};
    for (let i = 0; i < retry; i++) {
      try {
        const el = await driver.$(selector);
        await el.waitForDisplayed({ timeout });
        return true;
      } catch {
        if (i === retry - 1) throw new Error(`Element not visible: ${selector}`);
        await driver.pause(1000);
      }
    }
    return false;
  },

  /**
   * Assert element has specific text
   */
  async toHaveText(
    driver: WebdriverIO.Browser,
    selector: string,
    expectedText: string
  ): Promise<boolean> {
    const el = await driver.$(selector);
    const actualText = await el.getText();
    if (!actualText.includes(expectedText)) {
      throw new Error(
        `Text mismatch. Expected: "${expectedText}", Got: "${actualText}"`
      );
    }
    return true;
  },

  /**
   * Assert element is clickable
   */
  async toBeClickable(
    driver: WebdriverIO.Browser,
    selector: string
  ): Promise<boolean> {
    const el = await driver.$(selector);
    const isEnabled = await el.isEnabled();
    const isDisplayed = await el.isDisplayed();
    if (!isEnabled || !isDisplayed) {
      throw new Error(`Element not clickable: ${selector}`);
    }
    return true;
  },

  // ─── Navigation Assertions ───────────────────────────────────────────────────

  /**
   * Assert URL matches expected pattern
   */
  async toHaveUrl(
    driver: WebdriverIO.Browser,
    expectedUrl: string | RegExp
  ): Promise<boolean> {
    const currentUrl = await driver.getUrl();
    if (expectedUrl instanceof RegExp) {
      if (!expectedUrl.test(currentUrl)) {
        throw new Error(`URL mismatch. Expected: ${expectedUrl}, Got: ${currentUrl}`);
      }
    } else {
      if (currentUrl !== expectedUrl) {
        throw new Error(`URL mismatch. Expected: ${expectedUrl}, Got: ${currentUrl}`);
      }
    }
    return true;
  },

  /**
   * Assert page title
   */
  async toHaveTitle(
    driver: WebdriverIO.Browser,
    expectedTitle: string | RegExp
  ): Promise<boolean> {
    const actualTitle = await driver.getTitle();
    if (expectedTitle instanceof RegExp) {
      if (!expectedTitle.test(actualTitle)) {
        throw new Error(`Title mismatch. Expected: ${expectedTitle}, Got: ${actualTitle}`);
      }
    } else {
      if (actualTitle !== expectedTitle) {
        throw new Error(`Title mismatch. Expected: ${expectedTitle}, Got: ${actualTitle}`);
      }
    }
    return true;
  },

  // ─── Form Assertions ────────────────────────────────────────────────────────

  /**
   * Assert input field has value
   */
  async toHaveValue(
    driver: WebdriverIO.Browser,
    selector: string,
    expectedValue: string
  ): Promise<boolean> {
    const el = await driver.$(selector);
    const actualValue = await el.getValue();
    if (actualValue !== expectedValue) {
      throw new Error(`Value mismatch. Expected: "${expectedValue}", Got: "${actualValue}"`);
    }
    return true;
  },

  /**
   * Assert input is empty
   */
  async toBeEmpty(
    driver: WebdriverIO.Browser,
    selector: string
  ): Promise<boolean> {
    const el = await driver.$(selector);
    const value = await el.getValue();
    if (value !== "") {
      throw new Error(`Expected empty input, got: "${value}"`);
    }
    return true;
  },

  // ─── List Assertions ─────────────────────────────────────────────────────────

  /**
   * Assert list has expected number of items
   */
  async toHaveCount(
    driver: WebdriverIO.Browser,
    selector: string,
    expectedCount: number
  ): Promise<boolean> {
    const elements = await driver.$$(selector);
    if (elements.length !== expectedCount) {
      throw new Error(
        `Count mismatch. Expected: ${expectedCount}, Got: ${elements.length}`
      );
    }
    return true;
  },

  /**
   * Assert list contains specific item
   */
  async listToContain(
    driver: WebdriverIO.Browser,
    listSelector: string,
    itemText: string
  ): Promise<boolean> {
    const items = await driver.$$(listSelector);
    for (const item of items) {
      const text = await item.getText();
      if (text.includes(itemText)) return true;
    }
    throw new Error(`Item not found in list: ${itemText}`);
  },

  // ─── iOS-Specific ─────────────────────────────────────────────────────────

  /**
   * iOS: Assert element has accessibility label
   */
  async iOSHaveAccessibilityLabel(
    driver: WebdriverIO.Browser,
    selector: string,
    label: string
  ): Promise<boolean> {
    const el = await driver.$(selector);
    const accessibilityLabel = await el.getAttribute("accessibilityLabel");
    if (accessibilityLabel !== label) {
      throw new Error(`Accessibility label mismatch. Expected: ${label}`);
    }
    return true;
  },

  // ─── Android-Specific ──────────────────────────────────────────────────────

  /**
   * Android: Assert element has content description
   */
  async androidHaveContentDescription(
    driver: WebdriverIO.Browser,
    selector: string,
    description: string
  ): Promise<boolean> {
    const el = await driver.$(selector);
    const contentDesc = await el.getAttribute("contentDescription");
    if (contentDesc !== description) {
      throw new Error(`Content description mismatch. Expected: ${description}`);
    }
    return true;
  },
};

// ─── AI Self-Healing Helpers ─────────────────────────────────────────────────

export const selfHealing = {
  /**
   * Find element using multiple strategies
   */
  async findElement(
    driver: WebdriverIO.Browser,
    strategies: Array<{ type: string; value: string }>
  ): Promise<WebdriverIO.Element | null> {
    for (const strategy of strategies) {
      try {
        switch (strategy.type) {
          case "accessibilityId":
            return await driver.$(`~${strategy.value}`);
          case "text":
            return await driver.$(`//*[text()="${strategy.value}"]`);
          case "className":
            return await driver.$(strategy.value);
          default:
            return await driver.$(strategy.value);
        }
      } catch {
        continue;
      }
    }
    return null;
  },

  /**
   * Take screenshot and report failure
   */
  async reportFailure(
    driver: WebdriverIO.Browser,
    testName: string,
    error: Error
  ): Promise<void> {
    const screenshot = await driver.takeScreenshot();
    console.error(`Test failed: ${testName}`);
    console.error(`Error: ${error.message}`);
    console.error(`Screenshot: data:image/png;base64,${screenshot}`);
  },
};

export default { ...assertions, selfHealing };
