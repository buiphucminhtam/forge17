import { Router, Request, Response } from "express";
import { z } from "zod";
import { {{Resource}}Service } from "@/services";
import { validateRequest, asyncHandler } from "@/middleware";
import { authMiddleware } from "@/middleware/auth";

const router = Router();

// Validation schemas
const createSchema = z.object({
  body: z.object({
    name: z.string().min(1).max(255),
    description: z.string().max(1000).optional(),
  }),
});

const updateSchema = z.object({
  params: z.object({ id: z.string().uuid() }),
  body: z.object({
    name: z.string().min(1).max(255).optional(),
    description: z.string().max(1000).optional(),
  }),
});

// GET /api/{{resources}} - List all
router.get(
  "/",
  authMiddleware,
  asyncHandler(async (req: Request, res: Response) => {
    const {{resources}} = await {{Resource}}Service.findAll({
      userId: req.user!.id,
    });
    res.json({ data: {{resources}} });
  })
);

// GET /api/{{resources}}/:id - Get one
router.get(
  "/:id",
  authMiddleware,
  validateRequest(updateSchema),
  asyncHandler(async (req: Request, res: Response) => {
    const {{resource}} = await {{Resource}}Service.findById(req.params.id);
    if (!{{resource}}) {
      res.status(404).json({ error: "{{Resource}} not found" });
      return;
    }
    res.json({ data: {{resource}} });
  })
);

// POST /api/{{resources}} - Create
router.post(
  "/",
  authMiddleware,
  validateRequest(createSchema),
  asyncHandler(async (req: Request, res: Response) => {
    const {{resource}} = await {{Resource}}Service.create({
      ...req.body,
      userId: req.user!.id,
    });
    res.status(201).json({ data: {{resource}} });
  })
);

// PUT /api/{{resources}}/:id - Update
router.put(
  "/:id",
  authMiddleware,
  validateRequest(updateSchema),
  asyncHandler(async (req: Request, res: Response) => {
    const {{resource}} = await {{Resource}}Service.update(
      req.params.id,
      req.body
    );
    if (!{{resource}}) {
      res.status(404).json({ error: "{{Resource}} not found" });
      return;
    }
    res.json({ data: {{resource}} });
  })
);

// DELETE /api/{{resources}}/:id - Delete
router.delete(
  "/:id",
  authMiddleware,
  validateRequest(updateSchema),
  asyncHandler(async (req: Request, res: Response) => {
    const deleted = await {{Resource}}Service.delete(req.params.id);
    if (!deleted) {
      res.status(404).json({ error: "{{Resource}} not found" });
      return;
    }
    res.status(204).send();
  })
);

export default router;
