# {{team}} — On-Call Rotation Schedule
# Generated by Forgewright v8.1

# Schedule Configuration
schedule:
  name: {{team}}-oncall
  rotation_length: {{rotationLength}}  # weekly | biweekly | monthly
  handoff_day: monday
  handoff_time: "09:00"  # UTC

# ─── Primary On-Call ─────────────────────────────────────────────────────────
primary:
  current:
    name: {{primaryOnCall}}
    email: {{primaryOnCallEmail}}
    phone: {{primaryOnCallPhone}}
    slack: "@{{primaryOnCallSlack}}"
    start_date: {{primaryOnCallStart}}

  next:
    name: {{primaryOnCallNext}}
    email: {{primaryOnCallNextEmail}}
    start_date: {{primaryOnCallNextStart}}

# ─── Secondary On-Call ─────────────────────────────────────────────────────
secondary:
  current:
    name: {{secondaryOnCall}}
    email: {{secondaryOnCallEmail}}
    slack: "@{{secondaryOnCallSlack}}"
    start_date: {{secondaryOnCallStart}}

  next:
    name: {{secondaryOnCallNext}}
    email: {{secondaryOnCallNextEmail}}
    start_date: {{secondaryOnCallNextStart}}

# ─── Escalation Path ─────────────────────────────────────────────────────────
escalation:
  level_1: primary_oncall
  level_2: secondary_oncall
  level_3: engineering_lead
  level_4: engineering_manager
  level_5: vp_engineering

# ─── Response Time SLAs ──────────────────────────────────────────────────────
sla:
  sev1_critical:
    acknowledgement: 5m
    resolution_target: 30m
    escalation_if_not_ack: 5m

  sev2_high:
    acknowledgement: 15m
    resolution_target: 2h
    escalation_if_not_ack: 15m

  sev3_medium:
    acknowledgement: 1h
    resolution_target: 8h
    escalation_if_not_ack: 1h

  sev4_low:
    acknowledgement: 4h
    resolution_target: 24h
    escalation_if_not_ack: 4h

# ─── Rotation Calendar (Next 12 Weeks) ──────────────────────────────────────
rotation:
  - week: 1
    primary: {{primaryOnCall}}
    secondary: {{secondaryOnCall}}
    start: {{week1Start}}

  - week: 2
    primary: {{primaryOnCallNext}}
    secondary: {{secondaryOnCallNext}}
    start: {{week2Start}}

  {{#each rotation}}
  - week: {{add @index 3}}
    primary: {{this.primary}}
    secondary: {{this.secondary}}
    start: {{this.start}}
  {{/each}}

# ─── blackout Dates (No Handoffs) ───────────────────────────────────────────
blackout_dates:
  - date: {{holiday1}}
    reason: {{holiday1Reason}}
    primary_covered_by: {{holiday1CoveredBy}}

# ─── Time Zones ──────────────────────────────────────────────────────────────
time_zones:
  primary_region: {{primaryRegion}}
  secondary_region: {{secondaryRegion}}
  primary_offset: {{primaryOffset}}  # e.g., "-07:00"

# ─── Contact Information ──────────────────────────────────────────────────────
contacts:
  pagerduty:
    escalation_policy_id: {{pagerdutyPolicyId}}
    schedule_id: {{pagerdutyScheduleId}}

  slack_channels:
    oncall: "#oncall-{{team}}"
    incidents: "#incidents"
    alerts: "#alerts-{{team}}"

  emergency_contacts:
    security_team: "{{securityTeamContact}}"
    infrastructure_team: "{{infraTeamContact}}"
    oncall_manager: "{{managerContact}}"
