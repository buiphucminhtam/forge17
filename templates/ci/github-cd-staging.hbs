# {{project.name}} — CD Staging Pipeline
# Generated by Forgewright v8.1

name: CD Staging

on:
  push:
    branches: [develop]

env:
  NODE_VERSION: {{default ci.nodeVersion "20"}}
  REGISTRY: ghcr.io
  IMAGE_NAME: ${{ github.repository }}

jobs:
  build-and-deploy:
    name: Build & Deploy to Staging
    runs-on: ubuntu-latest
    environment: staging
    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js ${{ env.NODE_VERSION }}
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Run tests
        run: {{default ci.testCommand "npm test"}}

      - name: Build
        run: npm run build

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Extract metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}
          tags: |
            type=ref,event=branch
            type=sha,prefix=,suffix=,format=short

      - name: Build and push Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: Deploy to Staging
        run: |
          # Deploy command (customize for your infrastructure)
          echo "Deploying to staging..."
          # kubectl set image deployment/{{project.slug}} {{project.slug}}=${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}:${{ github.sha }}
          # kubectl rollout status deployment/{{project.slug}} -n staging

      - name: Health check
        run: |
          echo "Waiting for deployment..."
          sleep 10
          curl -f https://staging.${{ github.repository }}.example.com/health || exit 1

      - name: Notify on failure
        if: failure()
        run: |
          echo "Staging deployment failed!"
