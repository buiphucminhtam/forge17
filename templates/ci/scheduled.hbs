# {{project.name}} — Scheduled Jobs
# Generated by Forgewright v8.1

name: Scheduled Jobs

on:
  schedule:
    # Run at midnight daily
    - cron: "0 0 * * *"
  workflow_dispatch:
    inputs:
      job:
        description: Job to run
        required: true
        default: all
        type: choice
        options:
          - all
          - cleanup
          - health-check
          - metrics
          - dependency-audit

env:
  NODE_VERSION: {{default ci.nodeVersion "20"}}

jobs:
  # ─── Daily Health Check ────────────────────────────────────────────────────
  health-check:
    name: Health Check
    runs-on: ubuntu-latest
    if: github.event_name == 'schedule' || github.event.inputs.job == 'all' || github.event.inputs.job == 'health-check'
    steps:
      - uses: actions/checkout@v4

      - name: Health check
        run: |
          echo "Running health check..."
          for url in \
            "https://${{ github.repository }}.example.com/health" \
            "https://staging.${{ github.repository }}.example.com/health"; do
            echo "Checking: $url"
            STATUS=$(curl -s -o /dev/null -w "%{http_code}" "$url")
            if [[ "$STATUS" -ge 200 && "$STATUS" -lt 400 ]]; then
              echo "✓ $url: OK ($STATUS)"
            else
              echo "✗ $url: FAILED ($STATUS)"
              # Could trigger alert here
            fi
          done

  # ─── Dependency Audit ──────────────────────────────────────────────────────
  dependency-audit:
    name: Dependency Audit
    runs-on: ubuntu-latest
    if: github.event_name == 'schedule' || github.event.inputs.job == 'all' || github.event.inputs.job == 'dependency-audit'
    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Run npm audit
        run: npm audit --audit-level=high

      - name: Check for outdated packages
        run: |
          npm outdated --json --long --depth=0 | tee outdated.json
          if [[ -s outdated.json ]]; then
            echo "Outdated packages found:"
            cat outdated.json | jq -r 'keys[] as $k | "\($k): current=\(.[$k].current) wanted=\(.[$k].wanted) latest=\(.[$k].latest)"'
          fi

  # ─── Cleanup Old Artifacts ─────────────────────────────────────────────────
  cleanup:
    name: Cleanup Old Artifacts
    runs-on: ubuntu-latest
    if: github.event_name == 'schedule' || github.event.inputs.job == 'all' || github.event.inputs.job == 'cleanup'
    steps:
      - name: Delete old artifacts
        uses: actions/github-script@v7
        with:
          script: |
            const artifacts = await github.rest.actions.listArtifactsForRepo({
              owner: context.repo.owner,
              repo: context.repo.repo,
              per_page: 100,
            });

            const sevenDaysAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;

            for (const artifact of artifacts.data.artifacts) {
              if (new Date(artifact.updated_at).getTime() < sevenDaysAgo) {
                console.log(`Deleting artifact: ${artifact.name} (${artifact.id})`);
                await github.rest.actions.deleteArtifact({
                  owner: context.repo.owner,
                  repo: context.repo.repo,
                  artifact_id: artifact.id,
                });
              }
            }

      - name: Delete old workflow runs
        uses: actions/github-script@v7
        with:
          script: |
            const runs = await github.rest.actions.listWorkflowRunsForRepo({
              owner: context.repo.owner,
              repo: context.repo.repo,
              per_page: 100,
            });

            const thirtyDaysAgo = Date.now() - 30 * 24 * 60 * 60 * 1000;

            for (const run of runs.data.workflow_runs) {
              if (run.conclusion !== null && new Date(run.created_at).getTime() < thirtyDaysAgo) {
                console.log(`Deleting run: ${run.name} #${run.run_number} (${run.id})`);
                await github.rest.actions.deleteWorkflowRun({
                  owner: context.repo.owner,
                  repo: context.repo.repo,
                  run_id: run.id,
                });
              }
            }

  # ─── Weekly Metrics Report ─────────────────────────────────────────────────
  metrics:
    name: Metrics Report
    runs-on: ubuntu-latest
    if: github.event_name == 'schedule' || github.event.inputs.job == 'all' || github.event.inputs.job == 'metrics'
    steps:
      - name: Generate metrics report
        run: |
          echo "# Metrics Report - $(date +%Y-%m-%d)"
          echo ""
          echo "## Test Coverage"
          echo "\`\`\`"
          echo "View coverage at: https://${{ github.repository }}/actions/runs/${{ github.run_id }}"
          echo "\`\`\`"
          echo ""
          echo "## Dependencies"
          echo "Run dependency-audit job to check for vulnerabilities."

      - name: Create issue for critical metrics
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            // Check for critical issues and create issue if needed
            console.log("Metrics report generated");
