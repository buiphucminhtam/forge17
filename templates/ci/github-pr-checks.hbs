# {{project.name}} — PR Checks
# Generated by Forgewright v8.1

name: PR Checks

on:
  pull_request:
    types: [opened, synchronize, reopened]
  pull_request_review:
    types: [submitted]

env:
  NODE_VERSION: {{default ci.nodeVersion "20"}}

jobs:
  # ─── Automated PR Checks ────────────────────────────────────────────────────
  pr-checks:
    name: Automated Checks
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'
    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js ${{ env.NODE_VERSION }}
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Lint
        run: {{default ci.lintCommand "npm run lint"}}

      - name: Type check
        run: npx tsc --noEmit

      - name: Test
        run: {{default ci.testCommand "npm test"}}

  # ─── Preview Deployment ─────────────────────────────────────────────────────
  preview:
    name: Preview
    runs-on: ubuntu-latest
    needs: pr-checks
    if: github.event.pull_request.draft == false
    environment:
      name: preview
      url: ${{ steps.preview.outputs.url }}
    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js ${{ env.NODE_VERSION }}
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build

      - name: Deploy Preview
        id: preview
        run: |
          echo "Deploying preview..."
          # Customize for your preview environment (Vercel, Netlify, etc.)
          # PREVIEW_URL=$(deploy-command --pr ${{ github.event.pull_request.number }})
          # echo "url=$PREVIEW_URL" >> $GITHUB_OUTPUT

      - name: Comment PR
        uses: actions/github-script@v7
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: 'Preview deployed to: ${{ steps.preview.outputs.url }}'
            })

  # ─── Code Review ───────────────────────────────────────────────────────────
  code-review:
    name: Code Review
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request_review'
    steps:
      - name: Check review status
        run: |
          if [[ "${{ github.event.review.state }}" == "APPROVED" ]]; then
            echo "PR approved! Ready for merge."
          elif [[ "${{ github.event.review.state }}" == "CHANGES_REQUESTED" ]]; then
            echo "Changes requested. Please address feedback."
            exit 1
          else
            echo "Review pending."
          fi

  # ─── Merge Readiness ───────────────────────────────────────────────────────
  merge-check:
    name: Merge Readiness
    runs-on: ubuntu-latest
    needs: [pr-checks, preview]
    if: always()
    steps:
      - name: Check status
        run: |
          if [[ "${{ needs.pr-checks.result }}" == "success" ]] && [[ "${{ needs.preview.result }}" != "failure" ]]; then
            echo "All checks passed! PR is ready for merge."
          else
            echo "Some checks failed. Please review."
            exit 1
          fi
